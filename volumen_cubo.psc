Algoritmo volumen_cubo
	Definir lado1, lado2,lado3, volumen Como Real
	Escribir 'Ingresar la longitud de un lado del cubo para mostrar su volumen'
	Escribir 'presione tecla para continuar...'
	Esperar Tecla
	Borrar Pantalla
	Escribir 'ingrese los lados del cubo'
	Leer lado1,lado2, lado3 
	Borrar Pantalla
	volumen = lado1*lado2*lado3
	Escribir ' el volumen del cubo es: ' volumen 
	
FinAlgoritmo
